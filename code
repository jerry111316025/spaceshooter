import javax.swing.*;
import java.awt.*;
import java.awt.event.*;
import java.util.ArrayList;
import java.util.Iterator;
import java.util.Random;

public class SpaceShooter extends JPanel implements ActionListener, KeyListener {

    // 遊戲設定
    private final int WIDTH = 500;
    private final int HEIGHT = 600;
    private final int PLAYER_SIZE = 30;
    private final int BULLET_WIDTH = 5;
    private final int BULLET_HEIGHT = 10;
    private final int METEOR_SIZE = 40;

    // 遊戲狀態
    private boolean isRunning = false;
    private boolean isGameOver = false;
    private Timer timer;
    private int score = 0;
    private int difficultyLevel = 1;

    // 玩家位置
    private int playerX;
    private int playerY;

    // 按鍵狀態 (解決移動延遲問題)
    private boolean leftPressed = false;
    private boolean rightPressed = false;

    // 物件列表
    private ArrayList<Rectangle> bullets;
    private ArrayList<Rectangle> meteors;
    private Random random;

    public SpaceShooter() {
        setPreferredSize(new Dimension(WIDTH, HEIGHT));
        setBackground(Color.BLACK);
        setFocusable(true);
        addKeyListener(this);

        initGame();

        // 設定遊戲迴圈 (每 15 毫秒更新一次畫面)
        timer = new Timer(15, this);
        timer.start();
    }

    // 初始化遊戲數據
    private void initGame() {
        playerX = WIDTH / 2 - PLAYER_SIZE / 2;
        playerY = HEIGHT - 60;
        bullets = new ArrayList<>();
        meteors = new ArrayList<>();
        random = new Random();
        score = 0;
        difficultyLevel = 1;
        isRunning = true;
        isGameOver = false;
    }

    @Override
    protected void paintComponent(Graphics g) {
        super.paintComponent(g);

        // 畫飛機 (簡單的三角形)
        g.setColor(Color.CYAN);
        int[] xPoints = { playerX, playerX + PLAYER_SIZE / 2, playerX + PLAYER_SIZE };
        int[] yPoints = { playerY + PLAYER_SIZE, playerY, playerY + PLAYER_SIZE };
        g.fillPolygon(xPoints, yPoints, 3);

        // 畫子彈
        g.setColor(Color.YELLOW);
        for (Rectangle bullet : bullets) {
            g.fillRect(bullet.x, bullet.y, bullet.width, bullet.height);
        }

        // 畫隕石
        g.setColor(Color.RED);
        for (Rectangle meteor : meteors) {
            g.fillOval(meteor.x, meteor.y, meteor.width, meteor.height);
        }

        // 畫分數與資訊
        g.setColor(Color.WHITE);
        g.setFont(new Font("Arial", Font.BOLD, 18));
        g.drawString("Score: " + score, 10, 20);
        g.drawString("Level: " + difficultyLevel, 10, 40);

        // 畫 Game Over 畫面
        if (isGameOver) {
            g.setColor(Color.WHITE);
            g.setFont(new Font("Arial", Font.BOLD, 40));
            String msg = "GAME OVER";
            FontMetrics metrics = getFontMetrics(g.getFont());
            g.drawString(msg, (WIDTH - metrics.stringWidth(msg)) / 2, HEIGHT / 2);

            g.setFont(new Font("Arial", Font.PLAIN, 20));
            String msg2 = "Press Enter to Restart";
            metrics = getFontMetrics(g.getFont());
            g.drawString(msg2, (WIDTH - metrics.stringWidth(msg2)) / 2, HEIGHT / 2 + 40);
        }
    }

    @Override
    public void actionPerformed(ActionEvent e) {
        if (isRunning) {
            updatePlayer();
            updateBullets();
            updateMeteors();
            checkCollisions();

            // 根據分數增加難度
            if (score > difficultyLevel * 100) {
                difficultyLevel++;
            }
        }
        repaint(); // 重新繪製畫面
    }

    private void updatePlayer() {
        // 平滑移動邏輯
        if (leftPressed && playerX > 0) {
            playerX -= 5;
        }
        if (rightPressed && playerX < WIDTH - PLAYER_SIZE) {
            playerX += 5;
        }
    }

    private void updateBullets() {
        // 移動子彈
        for (int i = 0; i < bullets.size(); i++) {
            Rectangle bullet = bullets.get(i);
            bullet.y -= 10; // 子彈速度
            // 移除超出畫面的子彈
            if (bullet.y < 0) {
                bullets.remove(i);
                i--;
            }
        }
    }

    private void updateMeteors() {
        // 產生新隕石 (難度越高，產生機率越高)
        if (random.nextInt(100) < 2 + difficultyLevel) {
            int x = random.nextInt(WIDTH - METEOR_SIZE);
            meteors.add(new Rectangle(x, 0, METEOR_SIZE, METEOR_SIZE));
        }

        // 移動隕石
        for (int i = 0; i < meteors.size(); i++) {
            Rectangle meteor = meteors.get(i);
            meteor.y += 3 + (difficultyLevel / 2); // 隕石速度隨難度增加

            // 移除超出畫面的隕石
            if (meteor.y > HEIGHT) {
                meteors.remove(i);
                i--;
            }
        }
    }

    private void checkCollisions() {
        Rectangle playerRect = new Rectangle(playerX, playerY, PLAYER_SIZE, PLAYER_SIZE);

        Iterator<Rectangle> meteorIter = meteors.iterator();
        while (meteorIter.hasNext()) {
            Rectangle meteor = meteorIter.next();

            // 檢查：隕石撞飛機
            if (playerRect.intersects(meteor)) {
                isRunning = false;
                isGameOver = true;
            }

            // 檢查：子彈撞隕石
            Iterator<Rectangle> bulletIter = bullets.iterator();
            while (bulletIter.hasNext()) {
                Rectangle bullet = bulletIter.next();
                if (bullet.intersects(meteor)) {
                    meteorIter.remove(); // 移除隕石
                    bulletIter.remove(); // 移除子彈
                    score += 10;
                    break; // 跳出內層迴圈
                }
            }
        }
    }

    // --- 鍵盤輸入處理 ---

    @Override
    public void keyPressed(KeyEvent e) {
        int key = e.getKeyCode();

        if (key == KeyEvent.VK_LEFT) {
            leftPressed = true;
        }
        if (key == KeyEvent.VK_RIGHT) {
            rightPressed = true;
        }
        if (key == KeyEvent.VK_SPACE) {
            if (isRunning) {
                // 發射子彈 (從飛機中間發射)
                bullets.add(new Rectangle(playerX + PLAYER_SIZE / 2 - BULLET_WIDTH / 2, playerY, BULLET_WIDTH,
                        BULLET_HEIGHT));
            }
        }
        if (key == KeyEvent.VK_ENTER) {
            if (isGameOver) {
                initGame();
            }
        }
    }

    @Override
    public void keyReleased(KeyEvent e) {
        int key = e.getKeyCode();
        if (key == KeyEvent.VK_LEFT) {
            leftPressed = false;
        }
        if (key == KeyEvent.VK_RIGHT) {
            rightPressed = false;
        }
    }

    @Override
    public void keyTyped(KeyEvent e) {
    }

    // --- 主程式入口 ---
    public static void main(String[] args) {
        JFrame frame = new JFrame("Space Shooter Game");
        SpaceShooter game = new SpaceShooter();
        frame.add(game);
        frame.pack();
        frame.setDefaultCloseOperation(JFrame.EXIT_ON_CLOSE);
        frame.setLocationRelativeTo(null); // 視窗置中
        frame.setVisible(true);
    }
}
